modules = ["nodejs-20", "web", "bash"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 25580
externalPort = 3002

[[ports]]
localPort = 25849
externalPort = 3000

[deployment]
deploymentTarget = "cloudrun"

[userenv]

[userenv.shared]
LOG_LEVEL = "info"
ALLOWED_ORIGINS = "https://xpressprofx.com,https://www.xpressprofx.com"
APP_NAME = "XpressPro FX"
PORT = "8080"
NODE_ENV = "development"
ENABLE_DEMO_AUTH = "true"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "API Server"

[[workflows.workflow]]
name = "API Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=8080 NODE_ENV=development ENABLE_DEMO_AUTH=true node artifacts/api-server/dist/index.mjs"
waitForPort = 8080

[workflows.workflow.metadata]
outputType = "console"
