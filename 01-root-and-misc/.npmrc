# npm workspace configuration for XpressPro FX
#
# legacy-peer-deps: replaces pnpm's autoInstallPeers=false.
# Prevents npm from failing on peer dependency conflicts in large workspaces.
legacy-peer-deps=true
#
# NOTE: pnpm's minimumReleaseAge=1440 (24-hour supply-chain delay) has NO npm
# equivalent. To compensate:
#   1. Run `npm audit --audit-level=high` in CI before every deploy.
#   2. Do not merge dependency-bump PRs within 24 hours of the package release.
#   3. Pin exact versions for critical dependencies when possible.
#   4. Consider socket.dev or Verdaccio for registry-level protection.
