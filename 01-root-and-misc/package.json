{
  "name": "workspace",
  "version": "0.0.0",
  "private": true,
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "artifacts/*",
    "lib/*",
    "lib/integrations/*",
    "scripts"
  ],
  "scripts": {
    "start": "npm run start -w @workspace/api-server",
    "dev": "npm run dev -w @workspace/api-server",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "setup": "npm install"
  },
  "devDependencies": {
    "typescript": "~5.9.2",
    "prettier": "^3.8.1"
  },
  "overrides": {
    "esbuild": "0.27.3",
    "lodash": "4.18.1",
    "yaml": "2.8.3",
    "postcss": "8.5.10",
    "micromatch": {
      "picomatch": "2.3.2"
    },
    "vite": {
      "picomatch": "4.0.4"
    },
    "router": {
      "path-to-regexp": "8.4.0"
    },
    "minimatch": {
      "brace-expansion": "2.0.3"
    }
  }
}
