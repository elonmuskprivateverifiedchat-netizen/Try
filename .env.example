# =============================================================================
# NeXTrade / XpressPro FX — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# =============================================================================

# --- REQUIRED ---

# Port the API server listens on
PORT=8080

# Node environment (development | production)
NODE_ENV=production

# Strong random secret used to sign session cookies.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
SESSION_SECRET=

# --- ADMIN ACCOUNT (required for admin portal) ---

# Admin login email and password. Set both to provision the admin account at startup.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Optional: email address that receives admin alert mirrors
ADMIN_NOTIFY_EMAIL=

# --- CORS (required in production for non-Replit deployments) ---

# Comma-separated list of allowed frontend origins, e.g.:
#   https://yourdomain.com,https://www.yourdomain.com
# Leave unset in development (all origins allowed).
ALLOWED_ORIGINS=

# --- OPTIONAL: EMAIL PROVIDERS ---

# SendGrid (preferred). When set, transactional emails go via SendGrid.
SENDGRID_API_KEY=

# SMTP fallback (used only when SendGrid is not configured)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# --- OPTIONAL: BLOCKCHAIN PROVIDERS ---

# Alchemy or Infura API key (falls back to ethers public provider when missing)
ALCHEMY_API_KEY=
INFURA_API_KEY=

# --- OPTIONAL: MOONPAY INTEGRATION ---

MOONPAY_API_KEY=
MOONPAY_SECRET_KEY=
MOONPAY_WEBHOOK_SECRET=

# --- OPTIONAL: COINBASE COMMERCE ---

COINBASE_API_KEY=
COINBASE_API_SECRET=
COINBASE_WEBHOOK_SECRET=

# --- OPTIONAL: AI / OPENAI ---

# When set, live-chat uses the AI backend. Falls back to canned replies when missing.
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=

# --- OPTIONAL ---

# Enable demo auth endpoint and seed user (development only — never in production)
ENABLE_DEMO_AUTH=false

# Log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info
